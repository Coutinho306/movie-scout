TMDB_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
TAVILY_API_KEY=

POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=movie_scout

# Grafana monitoring — required, compose fails if unset
GF_SECURITY_ADMIN_PASSWORD=

# FastAPI backend
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/movie_scout
ALLOWED_ORIGINS=http://localhost:8501

# Streamlit frontend
API_BASE_URL=http://localhost:8000

# Qdrant vector store
#
# --- LOCAL (restore-and-run, no account needed) ---
# Start the bundled Qdrant service and restore the seed corpus:
#   docker compose up -d qdrant
#   make restore-seed
# Then use these values (defaults below):
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
#
# --- CLOUD (ingest / deploy) ---
# Create a free cluster at https://cloud.qdrant.io, paste its URL and key:
# QDRANT_URL=https://<cluster-id>.us-east4-0.gcp.cloud.qdrant.io:6333
# QDRANT_API_KEY=<your-api-key>

# Ingestion variant settings (optional — CLI flags override these)
EMBEDDER=openai-3-small
CHUNK_MAX_TOKENS=300
CHUNK_OVERLAP_TOKENS=50

LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=movie_scout
