TMDB_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
TAVILY_API_KEY=

POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=movie_scout

# Grafana monitoring
GF_SECURITY_ADMIN_PASSWORD=

# FastAPI backend
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/movie_scout
ALLOWED_ORIGINS=http://localhost:8501

# Streamlit frontend
API_BASE_URL=http://localhost:8000

# Qdrant Cloud — required. Create a free cluster at https://cloud.qdrant.io
# and paste its URL + API key here (used for both local runs and deploy).
QDRANT_URL=
QDRANT_API_KEY=

# Ingestion variant settings (optional — CLI flags override these)
EMBEDDER=openai-3-small
CHUNK_MAX_TOKENS=300
CHUNK_OVERLAP_TOKENS=50

LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=movie_scout
